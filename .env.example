# ============================================================
#  Sensória Spa — variáveis de ambiente
#  Copie para .env.local e preencha com os dados do SEU Supabase.
# ============================================================

# URL do projeto Supabase (pode ser público)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Service role key — USADA SÓ NO SERVIDOR (Route Handler /api/contact).
# NUNCA prefixe com NEXT_PUBLIC_ e nunca exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY=coloque-a-service-role-key-aqui

# (Opcional) Anon key pública, caso venha a usar o Supabase no cliente.
NEXT_PUBLIC_SUPABASE_ANON_KEY=coloque-a-anon-key-aqui

# ============================================================
#  Meta Ads — Pixel (navegador) + Conversions API (servidor)
#  Deixe em branco para desativar o rastreamento (o site funciona normalmente).
# ============================================================

# ID do Pixel (Gerenciador de Eventos → Fontes de dados). Público — usado no
# navegador (Pixel) e também no servidor (Conversions API).
NEXT_PUBLIC_META_PIXEL_ID=

# Token de acesso da Conversions API — USADO SÓ NO SERVIDOR.
# Gere em: Gerenciador de Eventos → seu Pixel → Configurações → Conversions API.
# NUNCA prefixe com NEXT_PUBLIC_.
META_CAPI_ACCESS_TOKEN=

# (Opcional) Código de teste da CAPI para validar eventos na aba "Testar eventos"
# do Gerenciador de Eventos. Remova em produção.
META_TEST_EVENT_CODE=

# ============================================================
#  Google — GA4 (navegador) + Google Ads (conversão pelo servidor)
#  Deixe em branco para desativar (o site funciona normalmente).
# ============================================================

# Google Tag: um único tag serve GA4 e Ads. Público (vai no navegador).
NEXT_PUBLIC_GOOGLE_TAG_ID=GT-WRDMXCKF
NEXT_PUBLIC_GA4_ID=G-QFWZ256E0J
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-11484787818

# --- Google Ads API (conversão server-side) — TUDO SÓ NO SERVIDOR ---
# Token de desenvolvedor: conta MCC → Ferramentas → API Center (exige aprovação).
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth2 (Google Cloud Console → Credenciais → ID do cliente OAuth "Desktop").
# O refresh token é gerado UMA vez (ver README/instruções).
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# ID da conta do Google Ads que registra a conversão (só dígitos, sem hífen).
GOOGLE_ADS_CUSTOMER_ID=
# (Opcional) ID da conta MCC/administradora, se o acesso for via ela.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ID da conversion action criada no Ads com origem "Importar" (só dígitos).
GOOGLE_ADS_CONVERSION_ACTION_ID=

# (Opcional) Versão da API e fuso horário DA CONTA do Ads.
GOOGLE_ADS_API_VERSION=v21
GOOGLE_ADS_TIMEZONE_OFFSET=-03:00

# ============================================================
#  Painel Admin (/admin) — visualização dos leads
#  Rota interna, fora do menu, protegida por senha.
# ============================================================

# Senha de acesso ao painel /admin. USADA SÓ NO SERVIDOR.
ADMIN_PASSWORD=

# Segredo para assinar o cookie de sessão (HMAC). USADO SÓ NO SERVIDOR.
# Gere uma string aleatória longa, ex.: `openssl rand -hex 32`.
ADMIN_SESSION_SECRET=

# ============================================================
#  Kommo CRM — envio automático dos leads (API v4)
#  Deixe em branco para desativar (o site funciona normalmente).
#  Token de longa duração de uma "integração privada" do Kommo.
# ============================================================

# Subdomínio da sua conta Kommo (sem barra no final).
KOMMO_BASE_URL=https://SEUSUBDOMINIO.kommo.com

# Token de acesso de longa duração — USADO SÓ NO SERVIDOR. Nunca NEXT_PUBLIC_.
KOMMO_ACCESS_TOKEN=

# (Opcional) Funil e estágio de destino. Vazio = funil e 1º estágio padrão.
KOMMO_PIPELINE_ID=
KOMMO_STATUS_ID=

# (Opcional) Tag aplicada ao lead no Kommo (padrão: "Site").
KOMMO_TAG=Site
